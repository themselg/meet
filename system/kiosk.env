# Configuracion del kiosko. Editar en /etc/meeting-room/kiosk.env (persiste entre updates).

# VM_MODE=1: render por software (VM sin aceleracion 3D). Poner en 0 en hardware real.
VM_MODE=1

# URL del backend y de la pantalla del kiosko
SERVER_URL=http://localhost
KIOSK_URL=http://localhost/kiosk

# Binario de chromium (EPEL lo instala como chromium-browser)
CHROMIUM_BIN=/usr/bin/chromium-browser

# Flags extra para chromium, separados por espacio (opcional)
#CHROMIUM_EXTRA_FLAGS=
