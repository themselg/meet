# Permite al backend reiniciar UNICAMENTE el servicio del kiosko (boton "Terminar reunion")
meeting-room ALL=(root) NOPASSWD: /usr/bin/systemctl restart meeting-room-kiosk.service

# Permite al panel ejecutar el instalador/actualizador de la app.
meeting-room ALL=(root) NOPASSWD: /usr/bin/systemd-run --wait --collect --unit=meeting-room-update /opt/meeting-room/install.sh
